{
  "$schema": "https://schemas.gettheflo.de/brand/typography/v1.json",
  "meta": {
    "name": "GettheFlo Brand Typography",
    "version": "0.2.0",
    "updated": "2026-05-18",
    "philosophy": "DM Sans bleibt Brand-Schrift für markante Stellen (Logo, Headlines, Marketing-Hero). Geist ergänzt als ruhige UI-Schrift für Body + Datentabellen im Cockpit. JetBrains Mono für Code + Labels + Mikrokopie. Klares Pairing: Brand spürbar in Display, Tool-Charakter in UI.",
    "evolution": "Stand 30.04.2026 hatte DM Sans throughout. Mit dem Light-Mode-Switch + Cockpit-Anwendung kommt Geist als zweite Sans-Familie dazu — Brand-Schrift bleibt in Display + Logo, Cockpit-UI nutzt Geist für ruhige Lesbarkeit in Daten-dichten Layouts."
  },
  "families": {
    "display": {
      "name": "DM Sans",
      "role": "Brand-Schrift. Headlines, Logo-Wort-Mark, Marketing-Hero, große Display-Texte.",
      "stack": "'DM Sans', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "weights": [300, 400, 500, 700],
      "variable": true,
      "license": "OFL",
      "source": {
        "google-fonts": "https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,500;0,9..40,700;1,9..40,300&display=swap"
      }
    },
    "ui": {
      "name": "Geist",
      "role": "Cockpit-UI-Schrift. Body, Tabellen, Inputs, Buttons, Tabs. Ruhige Lesbarkeit in Daten-dichten Flächen.",
      "stack": "'Geist', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "weights": [300, 400, 500, 600, 700],
      "variable": true,
      "license": "OFL",
      "source": {
        "google-fonts": "https://fonts.googleapis.com/css2?family=Geist:wght@300..700&display=swap"
      }
    },
    "mono": {
      "name": "JetBrains Mono",
      "role": "Daten, Code-Snippets, Labels, Eyebrows, IDs, RE-Nr, Tag-Marker.",
      "stack": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
      "weights": [400, 500, 600],
      "variable": false,
      "license": "OFL",
      "source": {
        "google-fonts": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      }
    }
  },
  "scale": {
    "hero": {
      "value": "clamp(48px, 8vw, 96px)",
      "weight": 700,
      "letter-spacing": "-0.04em",
      "line-height": "0.95",
      "family": "display",
      "role": "Marketing-Hero / Speaker-Slide-Titel"
    },
    "display-xl": {
      "value": "48px",
      "weight": 700,
      "letter-spacing": "-0.035em",
      "line-height": "1.05",
      "family": "display",
      "role": "Sektion-Headlines auf Website / große Display-Texte"
    },
    "display-l": {
      "value": "36px",
      "weight": 700,
      "letter-spacing": "-0.03em",
      "line-height": "1.1",
      "family": "display",
      "role": "Person-Name in Cockpit-Hero / Page-Hero"
    },
    "display-m": {
      "value": "28px",
      "weight": 600,
      "letter-spacing": "-0.025em",
      "line-height": "1.15",
      "family": "display",
      "role": "Card-Titel / Sektion-Titel im Cockpit"
    },
    "title": {
      "value": "20px",
      "weight": 600,
      "letter-spacing": "-0.02em",
      "line-height": "1.25",
      "family": "ui",
      "role": "Workshop-Karten-Titel / Tab-Aktiv"
    },
    "subtitle": {
      "value": "16px",
      "weight": 500,
      "letter-spacing": "-0.01em",
      "line-height": "1.4",
      "family": "ui",
      "role": "Untertitel / Sektion-Header inline"
    },
    "body": {
      "value": "14px",
      "weight": 400,
      "letter-spacing": "0",
      "line-height": "1.55",
      "family": "ui",
      "role": "Body-Text / Beschreibungen / Mail-Body"
    },
    "body-strong": {
      "value": "14px",
      "weight": 500,
      "letter-spacing": "-0.005em",
      "line-height": "1.5",
      "family": "ui",
      "role": "Body hervorgehoben / Buttons / Tab-Inaktiv"
    },
    "caption": {
      "value": "12.5px",
      "weight": 400,
      "letter-spacing": "0",
      "line-height": "1.5",
      "family": "ui",
      "role": "Metadaten / sekundärer Text"
    },
    "label-mono": {
      "value": "10.5px",
      "weight": 500,
      "letter-spacing": "0.12em",
      "line-height": "1.4",
      "family": "mono",
      "transform": "uppercase",
      "role": "Labels / Eyebrows / Sektion-Marker"
    },
    "data-mono": {
      "value": "13px",
      "weight": 500,
      "letter-spacing": "0",
      "line-height": "1.4",
      "family": "mono",
      "role": "Zahlen / IDs / RE-Nr / Daten in Tabellen"
    }
  }
}
