{
  "$schema": "https://schemas.getthelo.de/brand/colors/v1.json",
  "meta": {
    "name": "GettheFlo Brand Colors",
    "version": "0.1.0",
    "updated": "2026-05-18",
    "philosophy": "Soft-Mac warm-persönlich. Helle Flächen, warmer Akzent statt buntiger Aurora-Farben."
  },
  "palette": {
    "bone": {
      "value": "#FAF8F4",
      "role": "Hauptfläche / Cockpit-Hintergrund / Mail-Body",
      "tailwind": "bg-bone"
    },
    "cream": {
      "value": "#F2EDE4",
      "role": "Sekundäre Fläche / Card-Subtle / Sidebar",
      "tailwind": "bg-cream"
    },
    "stone-100": {
      "value": "#E8E2D6",
      "role": "Borders soft / Trennlinien",
      "tailwind": "border-stone-soft"
    },
    "stone-300": {
      "value": "#C4BBA9",
      "role": "Borders default / Inputs / Pills neutral",
      "tailwind": "border-stone"
    },
    "warm-gray": {
      "value": "#8B8478",
      "role": "Text sekundär / Labels / Captions",
      "tailwind": "text-muted"
    },
    "ink-soft": {
      "value": "#3A332A",
      "role": "Text Body",
      "tailwind": "text-default"
    },
    "ink": {
      "value": "#1C1A17",
      "role": "Text Display / Headlines / Wort-Mark",
      "tailwind": "text-ink"
    },
    "cognac": {
      "value": "#A8632A",
      "role": "Primärer Akzent / Logo / CTAs / Brand-Highlights",
      "tailwind": "accent-cognac"
    },
    "cognac-soft": {
      "value": "#D4A77A",
      "role": "Akzent gedämpft / Hover-Subtle / Akzent-Hintergründe",
      "tailwind": "accent-cognac-soft"
    },
    "olive": {
      "value": "#6F7547",
      "role": "Success / positive Status / bestätigt-Pille",
      "tailwind": "status-success"
    },
    "olive-soft": {
      "value": "#A8AC83",
      "role": "Success-Subtle / Hintergründe für Success-Pillen",
      "tailwind": "status-success-soft"
    },
    "plum": {
      "value": "#7A5F6D",
      "role": "Sekundärer Akzent / Notizen / dezente Info",
      "tailwind": "accent-plum"
    },
    "rust": {
      "value": "#9F4A2A",
      "role": "Warning / offene Rechnung / Aufmerksamkeit",
      "tailwind": "status-warning"
    },
    "error": {
      "value": "#A23B26",
      "role": "Error / Block / harte Stops",
      "tailwind": "status-error"
    }
  },
  "semantic": {
    "background-primary": "bone",
    "background-elevated": "cream",
    "background-card": "bone",
    "border-soft": "stone-100",
    "border-default": "stone-300",
    "text-default": "ink-soft",
    "text-display": "ink",
    "text-muted": "warm-gray",
    "text-faint": "stone-300",
    "accent-primary": "cognac",
    "accent-secondary": "plum",
    "status-success": "olive",
    "status-warning": "rust",
    "status-error": "error"
  },
  "shadows": {
    "shadow-1": "0 1px 2px rgba(28, 26, 23, 0.04), 0 1px 3px rgba(28, 26, 23, 0.05)",
    "shadow-2": "0 4px 12px -2px rgba(28, 26, 23, 0.08), 0 2px 4px -1px rgba(28, 26, 23, 0.04)",
    "shadow-3": "0 10px 28px -6px rgba(168, 99, 42, 0.18), 0 4px 10px -2px rgba(28, 26, 23, 0.06)",
    "shadow-cognac": "0 4px 14px -2px rgba(168, 99, 42, 0.30), 0 2px 6px -1px rgba(168, 99, 42, 0.18)"
  },
  "radii": {
    "sm": "8px",
    "md": "14px",
    "lg": "20px",
    "xl": "28px",
    "pill": "999px"
  }
}
