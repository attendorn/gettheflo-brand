{
  "$schema": "https://schemas.gettheflo.de/brand/colors/v1.json",
  "meta": {
    "name": "GettheFlo Brand Colors",
    "version": "0.2.0",
    "updated": "2026-05-18",
    "philosophy": "Reduktion + Energie. Light-Mode-Bühne (heller, freundlicher als die alte Dark-Variante) + 5% Iridescent Aurora als Energie-Akzent. Wie Captain Marvel — Kraft ist immer da, leuchtet nur wenn's zählt.",
    "evolution": "Dieser Stand löst den Dark-Mode-Brand vom 30.04.2026 ab (Void/Surface-dominiert). Aurora bleibt zentrales Identity-Element, wird aber jetzt auf einer hellen Bühne inszeniert. Cockpit + Mails + Website teilen die Light-Mode-Basis."
  },
  "palette": {
    "bone": {
      "value": "#FAF8F4",
      "role": "Hauptfläche / Cockpit-Hintergrund / Website-Body / Mail-Body",
      "tailwind": "bg-bone"
    },
    "cream": {
      "value": "#F2EDE4",
      "role": "Sekundäre Fläche / Card-Subtle / Sidebar",
      "tailwind": "bg-cream"
    },
    "stone-100": {
      "value": "#E8E2D6",
      "role": "Borders soft / Trennlinien",
      "tailwind": "border-stone-soft"
    },
    "stone-300": {
      "value": "#C4BBA9",
      "role": "Borders default / Inputs / Pills neutral",
      "tailwind": "border-stone"
    },
    "warm-gray": {
      "value": "#8B8478",
      "role": "Text sekundär / Labels / Captions",
      "tailwind": "text-muted"
    },
    "ink-soft": {
      "value": "#2A2520",
      "role": "Text Body",
      "tailwind": "text-default"
    },
    "ink": {
      "value": "#0A0908",
      "role": "Text Display / Headlines / Wort-Mark / harte Akzente",
      "tailwind": "text-ink"
    }
  },
  "aurora": {
    "$comment": "Iridescent Energie-Palette — wird IMMER als Gradient eingesetzt, nie einzeln. Reservierte Stellen: Logo, Hover-States, Stat-Highlights, einzelne Schlüsselwörter in Headlines. Max 5% der Gesamtfläche.",
    "gold": "#FFD23F",
    "ember": "#FF6B35",
    "pink": "#FF3CAC",
    "violet": "#7B68EE",
    "cyan": "#00D4FF",
    "gradient": "linear-gradient(135deg, #FFD23F, #FF6B35, #FF3CAC, #7B68EE, #00D4FF)",
    "gradient-css": "linear-gradient(135deg, var(--aurora-gold), var(--aurora-ember), var(--aurora-pink), var(--aurora-violet), var(--aurora-cyan))",
    "animation": "background-size: 300% 300%; animation: aurora-shimmer 20s ease infinite;"
  },
  "status": {
    "success": {
      "value": "#5E7A3F",
      "role": "Status Success (bestätigt, erledigt, OK) — gedämpft für Light-Mode",
      "tailwind": "status-success"
    },
    "success-soft": {
      "value": "#A8AC83",
      "role": "Success-Subtle Hintergrund für Pillen"
    },
    "warning": {
      "value": "#B86A2A",
      "role": "Warning (offene Rechnung, Aufmerksamkeit) — gedämpft, KEINE Verwechslung mit Aurora-Ember"
    },
    "error": {
      "value": "#A23B26",
      "role": "Error / Block / harte Stops"
    }
  },
  "semantic": {
    "background-primary": "bone",
    "background-elevated": "cream",
    "background-card": "bone",
    "border-soft": "stone-100",
    "border-default": "stone-300",
    "text-default": "ink-soft",
    "text-display": "ink",
    "text-muted": "warm-gray",
    "text-faint": "stone-300",
    "accent-energy": "aurora.gradient",
    "status-success": "status.success",
    "status-warning": "status.warning",
    "status-error": "status.error"
  },
  "shadows": {
    "shadow-1": "0 1px 2px rgba(10, 9, 8, 0.04), 0 1px 3px rgba(10, 9, 8, 0.05)",
    "shadow-2": "0 4px 12px -2px rgba(10, 9, 8, 0.08), 0 2px 4px -1px rgba(10, 9, 8, 0.04)",
    "shadow-3": "0 10px 28px -6px rgba(10, 9, 8, 0.12), 0 4px 10px -2px rgba(10, 9, 8, 0.06)",
    "shadow-aurora": "0 4px 20px -2px rgba(255, 60, 172, 0.20), 0 2px 8px -1px rgba(123, 104, 238, 0.15)"
  },
  "radii": {
    "sm": "8px",
    "md": "14px",
    "lg": "20px",
    "xl": "28px",
    "pill": "999px"
  }
}
